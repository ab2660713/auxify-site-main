  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node .next/standalone/server.js",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "pnpm lint && pnpm typecheck",
    "format": "prettier --write \"src/**/*.{css,ts,tsx}\" \"scripts/**/*.mjs\" \"package.json\" \"tsconfig.json\" \"next.config.ts\" \"eslint.config.mjs\" \"postcss.config.mjs\" \"pnpm-workspace.yaml\" \"README.md\" \".prettierrc\"",
    "format:check": "prettier --check \"src/**/*.{css,ts,tsx}\" \"scripts/**/*.mjs\" \"package.json\" \"tsconfig.json\" \"next.config.ts\" \"eslint.config.mjs\" \"postcss.config.mjs\" \"pnpm-workspace.yaml\" \"README.md\" \".prettierrc\"",
    "test:chaos:drill": "node scripts/chaos-drill.mjs",
    "test:load:smoke": "node scripts/smoke-load.mjs",
    "test:load:stress": "node scripts/stress-load.mjs",
    "verify:deployment": "node scripts/verify-deployment.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@next/third-parties": "16.2.7",
    "@paper-design/shaders-react": "^0.0.76",
    "@radix-ui/react-slot": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.10.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24.12.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "prettier": "^3.4.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
